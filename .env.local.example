# Copy this file to .env.local and fill in real values.
# .env.local is gitignored. Do NOT commit secrets.

# Azure Static Web Apps deployment token.
# Get it from: Azure Portal -> your Static Web App -> "Manage deployment token".
SWA_CLI_DEPLOYMENT_TOKEN=

# Google OAuth credentials.
# Get from: Google Cloud Console -> APIs & Services -> Credentials -> OAuth 2.0 Client ID.
# Add http://localhost:4280/.auth/login/google/callback as an authorized redirect URI for local dev.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign In credentials.
# APPLE_CLIENT_ID: your Services ID (e.g. com.yourorg.appname)
# APPLE_CLIENT_SECRET: a signed JWT — see docs/superpowers/specs/2026-05-11-social-auth-sync-design.md
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
